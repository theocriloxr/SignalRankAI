## SignalRankAI environment (.env)
## IMPORTANT: do not commit real secrets.
## Since secrets were shared previously, rotate them in Telegram/Paystack/Binance.

# --- Core / access ---
OWNER_TELEGRAM_ID=1409578077
# Optional: legacy list used by some paths (comma-separated). Keep same as OWNER_TELEGRAM_ID if unsure.
OWNER_IDS=1409578077

# Secret used by /unlock <key> (rotating this immediately revokes old unlock grants)
BYPASS_KEY=SRK-OWNER-ONLY-948372

# --- Telegram ---
TELEGRAM_TOKEN=8063034474:AAFLhCbLJYNHUaSfqJWEgqGxMiSiK_MUqJY

# --- Database (Railway Postgres) ---
# Paste Railway Postgres plugin DATABASE_URL here.
DATABASE_URL=postgresql://postgres:kevkHFGSieZobCrILEAphQrxTSyPecyY@postgres.railway.internal:5432/railway

# --- Web / service ---
# Set per Railway service: web|bot|engine|worker
# Single-service mode (recommended for your setup): all
RUN_MODE=all

# Web domain (used for Paystack callback URLs)
PUBLIC_BASE_URL=https://signalrankai-production.up.railway.app

# Protects /admin/killswitch endpoints
ADMIN_API_TOKEN=Theophilus123/admin

# Auto-run Alembic migrations on boot (recommended)
AUTO_MIGRATE=true

# If Railway Postgres is slow to accept connections during boot, startup ops will retry.
DB_CONNECT_MAX_ATTEMPTS=12
DB_CONNECT_BACKOFF_SECONDS=2

# Optional one-time wipe (web service only): set true for one deploy then remove.
FRESH_START=false

# --- Payments (Paystack) ---
PAYMENTS_ENABLED=true
PAYSTACK_SECRET_KEY=sk_live_26884cd687c2a53d2055f8439b1ff4411215bf8f
# If you don't have a separate webhook secret, set this to PAYSTACK_SECRET_KEY.
PAYSTACK_WEBHOOK_SECRET=sk_live_26884cd687c2a53d2055f8439b1ff4411215bf8f

# Optional Paystack plan codes (if using plans in /upgrade)
PAYSTACK_PLAN_CODE_PREMIUM_MONTHLY=
PAYSTACK_PLAN_CODE_PREMIUM_QUARTERLY=
PAYSTACK_PLAN_CODE_PREMIUM_SEMIANNUAL=
PAYSTACK_PLAN_CODE_VIP_MONTHLY=

# --- Crypto + FX market data (AlphaVantage free tier safe defaults) ---
ALPHAVANTAGE_API_KEY=WI6AKPKWJWMHI64P

# Best liquid FX pairs (engine will still cap per cycle via FX_MAX_PAIRS)
FX_PAIRS=EURUSD,GBPUSD,USDJPY,USDCHF,AUDUSD,USDCAD,NZDUSD,EURJPY,GBPJPY,EURGBP
FX_TIMEFRAMES=1d
FX_MAX_PAIRS=3
ALPHAVANTAGE_MIN_SECONDS_BETWEEN_CALLS=15

# Optional crypto controls
CRYPTO_TRENDING_TOP_N=10
CRYPTO_TIMEFRAMES=5m,15m,1h,4h,1d

# --- Engine loop ---
# Sleep between cycles when no work / kill-switch is enabled.
CYCLE_SLEEP_SECONDS=60

# --- Dev flags ---
# In production keep DRY_RUN=false.
DRY_RUN=false

# --- Free tier behavior ---
FREE_DAILY_LIMIT=2
FREE_DELAY_MINUTES=30

# --- VIP seats ---
VIP_SEAT_LIMIT=15

# --- Optional exchange keys (NOT required unless you use them) ---
BINANCE_API_KEY=P95jlxvxI9qzDU2iQjFJmzBGYbJj49a1LnLGU9Xr12LutktVDLTrQiaGxQs4OiLb
BINANCE_API_SECRET=HkRQZ0QPkcA30MK3JqnQjeJssURNh6i0Y7shh0navb9T0pTMsIHPeOg9Y1RqLQVe

# --- Logging / runtime ---
LOG_LEVEL=INFO
DISPATCH_ENABLED=true

# --- Legacy/unused (kept as notes) ---
