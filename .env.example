
# SignalRankAI (.env.example)
# Do NOT commit real secrets. Keep this file as placeholders.

# --- Telegram ---
TELEGRAM_TOKEN=
OWNER_TELEGRAM_ID=
BYPASS_KEY=

# --- Runtime ---
ENV=local
LOG_LEVEL=INFO
DRY_RUN=true
DISPATCH_ENABLED=true

# VIP scarcity
VIP_SEAT_LIMIT=15

# --- Web/API ---
PORT=8000
PUBLIC_BASE_URL=http://localhost:8000
ADMIN_API_TOKEN=

# --- Database (Postgres recommended for production) ---
# Example: postgresql+asyncpg://user:pass@localhost:5432/signalrank
DATABASE_URL=

# --- Redis (rate limits, kill-switch, locks) ---
# Example: redis://localhost:6379/0
REDIS_URL=

# --- Payments (Paystack) ---
PAYMENTS_ENABLED=false
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=

# Paystack plan codes (create these in Paystack Dashboard)
PAYSTACK_PLAN_CODE_PREMIUM_MONTHLY=
PAYSTACK_PLAN_CODE_PREMIUM_QUARTERLY=
PAYSTACK_PLAN_CODE_PREMIUM_SEMIANNUAL=
PAYSTACK_PLAN_CODE_VIP_MONTHLY=

# --- Market data ---
# Optional CCXT/Exchange keys; not required for public endpoints.
BINANCE_API_KEY=
BINANCE_API_SECRET=
ALPHAVANTAGE_API_KEY=
OANDA_API_KEY=

# --- Monitoring ---
SENTRY_DSN=

# --- Feature flags ---
ENABLE_ML_WEIGHTING=false
