# Copy this file to .env and fill values; DO NOT commit secrets.

# Required
DATABASE_URL=
REDIS_URL=
TELEGRAM_BOT_TOKEN=
SENTRY_DSN=
NEWS_API_KEY=
XGBOOST_MODEL_PATH=
ML_MODEL_PATH=
RUN_MODE=engine
PAPER_MODE=0

# Optional / Operational
LOG_JSON=0
SENTRY_TRACES_SAMPLE_RATE=0.0
TELEGRAM_POOL_TIMEOUT=30
TELEGRAM_CONNECT_TIMEOUT=30
TELEGRAM_READ_TIMEOUT=30
TELEGRAM_WRITE_TIMEOUT=30

# Feature flags
ENABLE_NEWS=1
ENABLE_ML=0

# App tuning
DRY_RUN=1
MIN_TRADE_SIZE=0.001
MAX_ACTIVE_TRADES=5
RISK_PER_TRADE_PCT=1.0
