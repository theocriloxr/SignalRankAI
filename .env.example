# Required for bot to function
DATABASE_URL=postgresql://postgres:password@localhost:5432/signalrank
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_OWNER_ID=your_telegram_user_id

# API Keys for data
ALPHAVANTAGE_API_KEY=your_alphavantage_key_here
BINANCE_API_KEY=your_binance_key_here
BINANCE_API_SECRET=your_binance_secret_here

# FX Trading (optional)
FX_PAIRS=EURUSD,GBPUSD,USDJPY,AUDUSD,USDCAD,NZDUSD
FX_MAX_PAIRS_PER_CYCLE=3

# Payments (optional)
PAYSTACK_SECRET_KEY=your_paystack_key_here

# Trading Config
DRY_RUN=False
MIN_TRADE_SIZE=0.001
MAX_ACTIVE_TRADES=5
RISK_PER_TRADE_PCT=1.0

# Redis (optional, for state)
REDIS_URL=redis://localhost:6379/0
