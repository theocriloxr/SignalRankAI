DATABASE_URL=postgresql://postgres:postgres@localhost:5432/signalrank_test
REDIS_URL=
TELEGRAM_BOT_TOKEN=
SENTRY_DSN=
NEWS_API_KEY=
XGBOOST_MODEL_PATH=
ML_MODEL_PATH=ml/model.json
RUN_MODE=all
PAPER_MODE=false
ENABLE_NEWS=true
ENABLE_ML=true
LOG_JSON=false
SENTRY_TRACES_SAMPLE_RATE=0.0
TELEGRAM_POOL_TIMEOUT=30
TELEGRAM_CONNECT_TIMEOUT=30
TELEGRAM_READ_TIMEOUT=30
TELEGRAM_WRITE_TIMEOUT=30

# Monolith hardening knobs
AUTO_MIGRATE=false
ENGINE_CYCLE_SLEEP_SECONDS=30
ENGINE_UNIVERSE_CAP=20
OUTCOME_CHECK_INTERVAL_SECONDS=20
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=3
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
DB_RETRY_ATTEMPTS=3

# Strategy and execution quality profile defaults
IMP_STRATEGY_ENABLED=1
IMP_ONLY_MODE=0
RUN_ALL_STRATEGIES=1
USE_FALLBACK_STRATEGIES=1
IMP_FX_SESSION_FILTER_ENABLED=1
IMP_FX_ALLOWED_SESSIONS=london,newyork,overlap
EXPECTANCY_HARD_BLOCK_ENABLED=0
OPEN_SIGNALS_MAX_PER_ASSET=20
OPEN_SIGNALS_MAX_PER_CLASS=20
